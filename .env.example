# Firebase (públicas)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Base de datos (privada)
DATABASE_URL=

# Firebase Admin SDK (para verificación de tokens en servidor)
# Obtener desde: Firebase Console > Project Settings > Service Accounts > Generate Private Key
# El archivo JSON ya existe en el proyecto, usar esas credenciales
FIREBASE_PROJECT_ID=red-agricola-e06cc
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-fbsvc@red-agricola-e06cc.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# AEAT - Agencia Tributaria (verificación de CIF de empresas)
# Certificado digital en formato PEM (contenido del archivo .pem)
AEAT_CERT_PEM="-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----\n"
AEAT_KEY_PEM="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# Alternativa: Ruta al archivo de certificado (.pem o .p12)
# AEAT_CERT_PATH=/ruta/al/certificado.p12

# Stripe (pagos y suscripciones)
# Obtener desde: Stripe Dashboard > Developers > API keys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PREMIUM_PRICE_ID=price_... # ID del precio de la suscripción premium

# Node environment
NODE_ENV=production
